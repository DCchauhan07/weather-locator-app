<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Weather Locator App</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="container">
    <h1>Weather Locator App</h1>
    <p class="subtitle">Search live weather information by city</p>

    <form action="/weather" method="POST">
      <input 
        type="text" 
        name="city" 
        placeholder="Enter city name" 
        required
      >
      <button type="submit">Get Weather</button>
    </form>

    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>

    <% if (weather) { %>
      <div class="weather-card">
        <h2><%= weather.city %>, <%= weather.country %></h2>

        <div class="weather-row">
          <span class="label">Temperature</span>
          <span class="value"><%= weather.temperature %> °C</span>
        </div>

        <div class="weather-row">
          <span class="label">Feels Like</span>
          <span class="value"><%= weather.feels_like %> °C</span>
        </div>

        <div class="weather-row">
          <span class="label">Humidity</span>
          <span class="value"><%= weather.humidity %>%</span>
        </div>

        <div class="weather-row">
          <span class="label">Wind Speed</span>
          <span class="value"><%= weather.wind_speed %> kph</span>
        </div>

        <div class="weather-row">
          <span class="label">Condition</span>
          <span class="value"><%= weather.condition %></span>
        </div>
      </div>
    <% } %>

    <p class="footer-text">
      Powered by Node.js, Jenkins, Docker, and WeatherAPI
    </p>
  </div>
</body>
</html>
